{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "920px",
      "wideSize": "1320px"
    },
    "spacing": {
      "units": [
        "px",
        "em",
        "rem",
        "%",
        "vw",
        "vh"
      ],
      "blockGap": true,
      "padding": true,
      "margin": true
    },
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "palette": [
        {
          "slug": "bg",
          "name": "Background",
          "color": "#f7f9fc"
        },
        {
          "slug": "surface",
          "name": "Surface",
          "color": "#ffffff"
        },
        {
          "slug": "surface-light",
          "name": "Surface Light",
          "color": "#eef3fb"
        },
        {
          "slug": "text",
          "name": "Text",
          "color": "#172133"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "#52627d"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "#1f5fd6"
        },
        {
          "slug": "accent-hover",
          "name": "Accent Hover",
          "color": "#184db0"
        },
        {
          "slug": "border",
          "name": "Border",
          "color": "#d8e0ee"
        },
        {
          "slug": "code-bg",
          "name": "Code Background",
          "color": "#f1f5fb"
        }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Inter, Helvetica, Arial, sans-serif",
          "slug": "sans",
          "name": "Sans"
        },
        {
          "fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
          "slug": "mono",
          "name": "Mono"
        }
      ],
      "fontSizes": [
        {
          "slug": "xs",
          "size": "0.875rem",
          "name": "XS"
        },
        {
          "slug": "sm",
          "size": "1rem",
          "name": "S"
        },
        {
          "slug": "md",
          "size": "1.125rem",
          "name": "M"
        },
        {
          "slug": "lg",
          "size": "1.5rem",
          "name": "L"
        },
        {
          "slug": "xl",
          "size": "2rem",
          "name": "XL"
        },
        {
          "slug": "xxl",
          "size": "2.75rem",
          "name": "XXL"
        }
      ],
      "lineHeight": true
    },
    "border": {
      "radius": true,
      "width": true,
      "color": true
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--bg)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize": "var(--wp--preset--font-size--sm)",
      "lineHeight": "1.7"
    },
    "spacing": {
      "blockGap": "1.45rem"
    },
    "elements": {
      "button": {
        "color": {
          "background": "var(--wp--preset--color--accent)",
          "text": "#ffffff"
        },
        "border": {
          "radius": "8px"
        },
        "spacing": {
          "padding": {
            "top": "0.65rem",
            "right": "1rem",
            "bottom": "0.65rem",
            "left": "1rem"
          }
        },
        "typography": {
          "fontWeight": "600"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--accent-hover)"
          }
        }
      },
      "heading": {
        "typography": {
          "lineHeight": "1.25",
          "fontWeight": "700"
        }
      }
    },
    "blocks": {
      "core/paragraph": {
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "1.1rem"
          }
        }
      },
      "core/heading": {
        "typography": {
          "lineHeight": "1.25",
          "letterSpacing": "0.01em"
        },
        "spacing": {
          "margin": {
            "top": "1.9rem",
            "bottom": "0.9rem"
          }
        }
      },
      "core/list": {
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "1.3rem"
          },
          "padding": {
            "left": "1.2rem"
          }
        }
      },
      "core/quote": {
        "border": {
          "left": {
            "color": "var(--wp--preset--color--accent)",
            "width": "3px"
          },
          "radius": "0px"
        },
        "color": {
          "background": "var(--wp--preset--color--surface)"
        },
        "spacing": {
          "padding": {
            "top": "1rem",
            "right": "1.1rem",
            "bottom": "1rem",
            "left": "1.1rem"
          }
        }
      },
      "core/pullquote": {
        "border": {
          "top": {
            "color": "var(--wp--preset--color--border)",
            "width": "1px"
          },
          "bottom": {
            "color": "var(--wp--preset--color--border)",
            "width": "1px"
          }
        },
        "spacing": {
          "padding": {
            "top": "1.2rem",
            "bottom": "1.2rem"
          }
        }
      },
      "core/table": {
        "border": {
          "color": "var(--wp--preset--color--border)",
          "width": "1px"
        },
        "elements": {
          "link": {
            "color": {
              "text": "var(--wp--preset--color--accent)"
            }
          }
        },
        "color": {
          "background": "var(--wp--preset--color--surface)"
        },
        "spacing": {
          "margin": {
            "top": "1.3rem",
            "bottom": "1.5rem"
          }
        }
      },
      "core/code": {
        "color": {
          "background": "var(--wp--preset--color--code-bg)",
          "text": "var(--wp--preset--color--text)"
        },
        "border": {
          "radius": "8px"
        },
        "spacing": {
          "padding": {
            "top": "12px",
            "right": "14px",
            "bottom": "12px",
            "left": "14px"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "0.9rem"
        }
      },
      "core/preformatted": {
        "color": {
          "background": "var(--wp--preset--color--code-bg)"
        },
        "border": {
          "radius": "8px"
        },
        "spacing": {
          "padding": {
            "top": "14px",
            "right": "16px",
            "bottom": "14px",
            "left": "16px"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "0.9rem",
          "lineHeight": "1.55"
        }
      },
      "core/image": {
        "spacing": {
          "margin": {
            "top": "1.2rem",
            "bottom": "1.4rem"
          }
        },
        "border": {
          "radius": "8px"
        }
      },
      "core/separator": {
        "color": {
          "background": "var(--wp--preset--color--border)"
        },
        "spacing": {
          "margin": {
            "top": "2rem",
            "bottom": "2rem"
          }
        }
      },
      "core/buttons": {
        "spacing": {
          "blockGap": "0.8rem"
        }
      },
      "core/query-pagination": {
        "spacing": {
          "margin": {
            "top": "1.8rem"
          },
          "padding": {
            "top": "0.8rem"
          }
        },
        "typography": {
          "fontSize": "0.95rem"
        },
        "border": {
          "top": {
            "color": "var(--wp--preset--color--border)",
            "width": "1px"
          }
        }
      },
      "core/post-navigation-link": {
        "typography": {
          "fontSize": "0.95rem"
        }
      },
      "core/post-featured-image": {
        "border": {
          "radius": "10px"
        },
        "spacing": {
          "margin": {
            "top": "0.8rem",
            "bottom": "1.2rem"
          }
        }
      },
      "core/post-excerpt": {
        "color": {
          "text": "var(--wp--preset--color--muted)"
        }
      },
      "core/post-title": {
        "typography": {
          "lineHeight": "1.18"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "0.6rem"
          }
        }
      },
      "core/post-content": {
        "spacing": {
          "blockGap": "1.25rem"
        },
        "typography": {
          "lineHeight": "1.75"
        }
      },
      "core/html": {
        "spacing": {
          "margin": {
            "top": "1.4rem",
            "bottom": "1.4rem"
          }
        }
      },
      "core/shortcode": {
        "spacing": {
          "margin": {
            "top": "1.1rem",
            "bottom": "1.1rem"
          }
        }
      }
    },
    "css": ".wp-site-blocks{overflow-x:clip;}\n.wp-block-post-content{word-break:break-word;overflow-wrap:anywhere;}\n.wp-block-post-content :where(img,video,canvas,svg){max-width:100%;height:auto;}\n.wp-block-post-content :where(iframe,embed,object){max-width:100%;}\n.wp-block-post-content table{display:block;width:100%;max-width:100%;overflow-x:auto;border-collapse:collapse;}\n.wp-block-post-content pre{max-width:100%;overflow-x:auto;}\n.wp-block-post-content :where(code,kbd,samp){word-break:break-word;}\n.wp-block-post-content .wp-block-columns{gap:clamp(1rem,2vw,1.5rem);}\n.wp-block-post-content .wp-block-column{min-width:0;}\n.wp-block-post-content :where([style*='display:flex'],[style*='display: grid']){max-width:100%;}\n.is-legacy-page-content > * + *{margin-block-start:clamp(1rem,1.1vw,1.35rem);}\n.is-legacy-page-content :where(h1,h2,h3,h4,h5,h6){overflow-wrap:anywhere;}\n.is-legacy-page-content :where(ul,ol){padding-inline-start:1.25rem;}\n.is-legacy-page-content :where(.wp-block-button__link,a.wp-element-button){text-decoration:none;}\n.is-legacy-page-content :where(.wp-block-separator){margin-block:clamp(1.3rem,1.8vw,2rem);}\n@media (max-width: 782px){.wp-site-blocks{overflow-x:hidden;}.wp-block-post-content table{font-size:0.95rem;}}"
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    },
    {
      "name": "post-meta",
      "title": "Post Meta",
      "area": "uncategorized"
    },
    {
      "name": "sidebar",
      "title": "Sidebar",
      "area": "uncategorized"
    }
  ]
}
