{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1200px"
    },
    "spacing": {
      "units": ["px", "em", "rem", "%", "vw", "vh"],
      "blockGap": true,
      "padding": true,
      "margin": true
    },
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "palette": [
        { "slug": "bg", "name": "Background", "color": "#0b1020" },
        { "slug": "surface", "name": "Surface", "color": "#121a2b" },
        { "slug": "surface-light", "name": "Surface Light", "color": "#1b2640" },
        { "slug": "text", "name": "Text", "color": "#e6edf7" },
        { "slug": "muted", "name": "Muted", "color": "#9fb0cc" },
        { "slug": "accent", "name": "Accent", "color": "#4f8cff" },
        { "slug": "accent-hover", "name": "Accent Hover", "color": "#77a7ff" },
        { "slug": "border", "name": "Border", "color": "#26324d" },
        { "slug": "code-bg", "name": "Code Background", "color": "#0f1728" }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Inter, Helvetica, Arial, sans-serif",
          "slug": "sans",
          "name": "Sans"
        },
        {
          "fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
          "slug": "mono",
          "name": "Mono"
        }
      ],
      "fontSizes": [
        { "slug": "xs", "size": "0.875rem", "name": "XS" },
        { "slug": "sm", "size": "1rem", "name": "S" },
        { "slug": "md", "size": "1.125rem", "name": "M" },
        { "slug": "lg", "size": "1.5rem", "name": "L" },
        { "slug": "xl", "size": "2rem", "name": "XL" },
        { "slug": "xxl", "size": "2.75rem", "name": "XXL" }
      ],
      "lineHeight": true
    },
    "border": {
      "radius": true,
      "width": true,
      "color": true
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--bg)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--sans)",
      "fontSize": "var(--wp--preset--font-size--sm)",
      "lineHeight": "1.7"
    },
    "spacing": {
      "blockGap": "1.4rem"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--accent-hover)"
          }
        }
      },
      "heading": {
        "typography": {
          "lineHeight": "1.25",
          "fontWeight": "700"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}
